# ==============================================
# GlazeSmith Environment Variables
# ==============================================

# Fireworks AI — LLM inference on AMD Instinct MI300X GPUs
# Sign up at https://fireworks.ai to get your API key
FIREWORKS_API_KEY=fw_your_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
LLM_MODEL=accounts/fireworks/models/deepseek-v4-flash

# SDXL service URL (AMD ROCm GPU — internal Docker network)
SDXL_SERVICE_URL=http://sdxl:8001

# Frontend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000
